# Reddit API credentials
# Get these from https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USERNAME=your_bot_username
REDDIT_PASSWORD=your_bot_password

# Optional: override the default user-agent string
# REDDIT_USER_AGENT=script:KurtVonnebot:v1.0 (by u/your_bot_username)

# Comma-separated list of subreddits to monitor (no spaces around commas)
SUBREDDITS=books,literature,scifi

# How many posts/comments to fetch per poll cycle (max 100 per Reddit API)
FETCH_LIMIT=25

# Seconds to wait between poll cycles (minimum 60 recommended)
POLL_INTERVAL=60

# Set to "false" to only reply to posts, not comments
REPLY_TO_COMMENTS=true

# Path to the file that tracks already-replied IDs
REPLIED_FILE=replied.txt
