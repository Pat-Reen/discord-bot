# Discord bot token
# Get this from https://discord.com/developers/applications → your app → Bot → Token
DISCORD_TOKEN=your_bot_token_here

# Optional: comma-separated channel IDs that the bot will watch for keyword triggers.
# Leave blank (or remove the line) to watch every channel in every server.
# Example: WATCH_CHANNELS=123456789012345678,987654321098765432
WATCH_CHANNELS=
